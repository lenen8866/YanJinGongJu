<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="@dimen/dp_10"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:paddingRight="@dimen/dp_10"
    android:paddingLeft="@dimen/dp_10"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/item_recycle_font_iv"
        android:layout_marginLeft="@dimen/dp_10"
        android:layout_width="50dp"
        android:layout_height="50dp"/>

    <TextView
        android:id="@+id/item_recycle_font_tv_name"
        android:textColor="@color/black_color"
        android:layout_marginTop="7dp"
        android:layout_marginLeft="13dp"
        android:layout_toRightOf="@id/item_recycle_font_iv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/item_recycle_font_tv_size"
        android:textColor="@color/gray_9e9e9e"
        android:layout_marginTop="7dp"
        android:textSize="@dimen/sp_12"
        android:layout_marginLeft="13dp"
        android:layout_below="@id/item_recycle_font_tv_name"
        android:layout_toRightOf="@id/item_recycle_font_iv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/item_recycle_font_tv_caozuo"
        android:textColor="@color/gray_4c4c4c"
        android:layout_marginTop="@dimen/dp_10"
        android:textSize="@dimen/sp_14"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:gravity="center"
        android:layout_alignParentRight="true"
        android:layout_marginRight="@dimen/txt_size_20"
        android:layout_centerVertical="true"
        android:layout_width="100dp"
        android:layout_height="wrap_content"/>

</RelativeLayout>