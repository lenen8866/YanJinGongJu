<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.read.scriptures.EIUtils.ExpandGridView
        android:id="@+id/baike_classify_gridview"
        android:layout_width="fill_parent"
        android:layout_height="40dp"
        android:background="#faf7f7"
        android:minHeight="40dp"
        android:scrollbars="horizontal" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/common_color_line_bg" />

    <LinearLayout
        android:id="@+id/search_content"
        android:layout_width="match_parent"
        android:layout_height="@dimen/actionbar_height"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:id="@+id/linear_type"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:layout_margin="8dp"
            android:background="@drawable/edit_back_grey"
            android:gravity="center"
            android:orientation="horizontal">
            <!--<ImageView-->
            <!--android:id="@+id/iv_arrow"-->
            <!--android:layout_width="24dp"-->
            <!--android:layout_height="24dp"-->
            <!--android:src="@drawable/ic_right_arrow"/>-->

            <TextView
                android:id="@+id/tv_search_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="18dp"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:text="标题搜索"/>

            <ImageView
                android:id="@+id/ic_by_name"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_down_arrow"/>
        </LinearLayout>
        <com.read.scriptures.widget.ClearEditText
            android:id="@+id/baike_search_edt"
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:background="@drawable/edittext_rounded_bg"
            android:hint="在圣经百科中搜索"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/gray_4c4c4c"
            android:textColorHint="@color/gray_bdbdbd"
            android:textCursorDrawable="@null"
            android:textSize="@dimen/txt_size_16" />

        <TextView
            android:id="@+id/baike_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:layout_gravity="end|center"
            android:layout_marginBottom="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/custom_item_selector"
            android:clickable="true"
            android:gravity="center"
            android:paddingRight="10dp"
            android:paddingLeft="10dp"
            android:text="@string/search"
            android:textColor="#ff424142"
            android:textCursorDrawable="@null"
            android:textSize="16.0sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/search_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_below="@+id/search_content"
        android:layout_gravity="center_vertical"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/progressbar_color" />

    <View
        android:layout_width="fill_parent"
        android:layout_height="1dp"
        android:background="#F0d9d9d7" />

    <include layout="@layout/search_history" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.read.scriptures.widget.LoadListView
            android:id="@+id/baike_listview"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:cacheColorHint="#00000000"
            android:divider="#F0d9d9d7"
            android:dividerHeight="1dp"
            android:drawSelectorOnTop="false"
            android:fastScrollEnabled="true"
            android:listSelector="@drawable/selector_baike_list_item"
            android:scrollbars="vertical" />

        <!-- 字母滑块 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="2dp"
                android:layout_height="50dp" />

            <com.read.scriptures.view.QuickIndexBar
                android:id="@+id/quick_index_bar"
                android:layout_width="35dp"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">

            <TextView
                android:id="@+id/text_dialog"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_centerInParent="true"
                android:layout_marginBottom="70dp"
                android:background="@drawable/shap_bg_text_dialog"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </RelativeLayout>


</LinearLayout>