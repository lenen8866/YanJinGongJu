<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/rl_cate"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <!--   android:paddingLeft="13dp"
                    android:paddingRight="13dp"-->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_cate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingLeft="13dp"
            android:paddingRight="13dp" />

        <ImageView
            android:id="@+id/iv_cate_show"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@color/white"
            android:src="@drawable/down_arror"
            android:tint="@color/black"
            android:visibility="visible" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rl_author"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_author"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toLeftOf="@+id/iv_author_show"
            android:clipToPadding="false"
            android:paddingLeft="13dp"
            android:paddingRight="13dp" />

        <ImageView
            android:id="@+id/iv_author_show"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@color/white"
            android:src="@drawable/down_arror"
            android:tint="@color/black" />

    </RelativeLayout>


    <TextView
        android:id="@+id/tv_cate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E6E6E6"
        android:paddingLeft="15dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:textColor="#ff333333"
        android:textSize="15sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_book_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:fastScrollEnabled="true"
        app:fastScrollHorizontalThumbDrawable="@drawable/scroller_drawable"
        app:fastScrollHorizontalTrackDrawable="@drawable/scroller_bg_drawable"
        app:fastScrollVerticalThumbDrawable="@drawable/scroller_drawable"
        app:fastScrollVerticalTrackDrawable="@drawable/scroller_bg_drawable" />

    <!--书籍/专辑，准备添加中，耐心等候！-->

    <TextView
        android:id="@+id/tv_no_data"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="正在加载…"
        android:textColor="#999999"
        android:textSize="13sp"
        android:visibility="visible" />
</LinearLayout>