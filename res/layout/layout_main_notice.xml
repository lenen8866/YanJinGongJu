<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/icon_main_tips_bg">

    <TextView
        android:id="@+id/tv_notice_title"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_notice_tips"
        android:drawableRight="@drawable/icon_show_up"
        android:drawablePadding="10dp"
        android:gravity="center_vertical"
        android:text="通知通知通知通知通知"
        android:textColor="@color/black"
        android:textSize="15sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_notice_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginRight="15dp"
        android:padding="10dp"
        android:src="@drawable/ic_operation_close"
        app:layout_constraintBottom_toBottomOf="@+id/tv_notice_title"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_notice_title" />

    <TextView
        android:visibility="gone"
        android:id="@+id/tv_notice_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="50dp"
        android:drawablePadding="10dp"
        android:gravity="center_vertical"
        android:lineSpacingExtra="3dp"
        android:paddingBottom="10dp"
        android:text="通知通知通知通知通知知通知通知通知知通知通知通知通知通知通知通知通知通知通知通知通知"
        android:textColor="@color/black"
        android:textSize="15sp"
        app:layout_constraintLeft_toLeftOf="@+id/tv_notice_title"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_notice_title" />

</androidx.constraintlayout.widget.ConstraintLayout>