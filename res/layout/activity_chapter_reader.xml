<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_chapter_read"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#eeeeee"
    android:orientation="vertical">

    <include
        android:id="@+id/layout_title"
        layout="@layout/layout_chapter_read_title" />

    <View
        android:id="@+id/dex_line"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_below="@+id/layout_title"
        android:background="#ff333333" />

    <RelativeLayout
        android:layout_above="@+id/fl_view"
        android:id="@+id/rl_reader_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/dex_line"
        android:background="#dcd0ba">

        <com.read.scriptures.widget.TouchInterceptSlidingView
            android:id="@+id/sliding_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/layout_status" />

        <include
            android:id="@+id/layout_status"
            layout="@layout/layout_chapter_read_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true" />

        <TextView
            android:id="@+id/tv_item_txt"
            android:layout_width="30dp"
            android:layout_height="22dp"
            android:paddingLeft="8dp"
            android:gravity="center"
            android:textColor="#999999"
            android:text="121"
            android:textSize="15dp"
            android:visibility="gone"/>

    </RelativeLayout>

    <include
        android:id="@+id/layout_option"
        layout="@layout/layout_chapter_read_options"
        android:layout_width="match_parent"
        android:layout_height="@dimen/actionbar_height"
        android:layout_alignParentTop="true"
        android:background="#b0000000"
        android:visibility="gone" />

    <com.read.scriptures.view.AudioPlayingView
        android:id="@+id/fl_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:visibility="visible" />
</RelativeLayout>