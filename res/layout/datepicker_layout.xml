<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/common_color_list_line" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gray_f5f5f5">

        <TextView
            android:id="@+id/btn_cancel"
            style="@style/dg_33_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/sel_bg_trans_blue"
            android:padding="16dp"
            android:text="取消" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/cb_none_year"
                style="@style/Checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="忽略年份"
                android:textColor="@color/gray_4c4c4c"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/cb_lunar"
                style="@style/Checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="农历"
                android:textColor="@color/gray_4c4c4c"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_ensure"
            style="@style/dg_33_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:background="@drawable/sel_bg_trans_blue"
            android:padding="16dp"
            android:text="确定" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="15dp"
        android:paddingTop="15dp">

        <com.read.scriptures.widget.wheelview.WheelView
            android:id="@+id/year"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="4.0" />

        <com.read.scriptures.widget.wheelview.WheelView
            android:id="@+id/month"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="5.0" />

        <com.read.scriptures.widget.wheelview.WheelView
            android:id="@+id/day"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="5.0" />

        <com.read.scriptures.widget.wheelview.WheelView
            android:id="@+id/week"
            android:layout_width="70dp"
            android:layout_height="wrap_content" />
    </LinearLayout>


</LinearLayout>