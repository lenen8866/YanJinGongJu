<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_background"
    android:orientation="vertical"
    android:paddingTop="10dp" >

    <!-- 模式选择行（模式A/B）已彻底隐藏 -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/common_margin_8"
            android:layout_marginStart="@dimen/common_margin_8"
            android:text="@string/read_setting_reader_select"
            android:textColor="@color/voice_text_normal"
            android:textSize="@dimen/txt_size_16" />

        <Button
            android:id="@+id/radio_local"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="30dp"
            android:background="@drawable/btn_voice_radio_on"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:textColor="@color/white"
            android:text="@string/label_pause"
            android:visibility="gone"/>
        <View
            android:layout_width="5dp"
            android:layout_height="5dp"/>
        <RadioGroup
            android:id="@+id/radio_group"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="3"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/baidu_engine"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="30dp"
                android:background="@drawable/btn_voice_radio_selector"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:textColor="@color/voice_model_selector"
                android:button="@null"
                android:gravity="center"
                android:checked="false"
                android:visibility="gone"
                android:text="@string/modelA" />
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:visibility="gone"/>
            <RadioButton
                android:id="@+id/radio_engine"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="30dp"
                android:background="@drawable/btn_voice_radio_selector"
                android:textColor="@color/voice_model_selector"
                android:button="@null"
                android:gravity="center"
                android:checked="true"
                android:text="@string/modelB" />
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:visibility="gone"/>
            <RadioButton
                android:id="@+id/radio_ali"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="30dp"
                android:background="@drawable/btn_voice_radio_selector"
                android:textColor="@color/voice_model_selector"
                android:button="@null"
                android:gravity="center"
                android:text="@string/modelC"
                android:visibility="gone"
                />
            <View
                android:layout_width="5dp"
                android:layout_height="5dp"/>
        </RadioGroup>

    </LinearLayout>


    <!-- 音色选择行：保留，供用户选择音色 -->
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp" >

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >

            <RadioGroup
                android:id="@+id/radioGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/common_margin_8"
                android:paddingRight="@dimen/common_margin_8" >

                <RadioButton
                    android:id="@+id/radio_woman"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_woman" />

                <RadioButton
                    android:id="@+id/radio_soft"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_soft" />

                <RadioButton
                    android:id="@+id/radio_affine"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_affine" />

                <RadioButton
                    android:id="@+id/radio_sweet"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_sweet" />

                <RadioButton
                    android:id="@+id/radio_lolita"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_lolita" />

                <RadioButton
                    android:id="@+id/radio_natural"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_natural" />

                <RadioButton
                    android:id="@+id/radio_serious"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_serious" />

                <RadioButton
                    android:id="@+id/radio_man"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:checked="true"
                    android:text="@string/tts_voice_man" />

                <RadioButton
                    android:id="@+id/radio_man_two"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_man_two" />

                <RadioButton
                    android:id="@+id/radio_man_three"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_man_three" />

                <RadioButton
                    android:id="@+id/radio_man_four"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_man_four" />

                <RadioButton
                    android:id="@+id/radio_yueyu"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_yueyu" />

                <RadioButton
                    android:id="@+id/radio_taiwan"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_taiwan" />

                <RadioButton
                    android:id="@+id/radio_sichuan"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_sichuan" />

                <RadioButton
                    android:id="@+id/radio_dongbei"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_dongbei" />

                <RadioButton
                    android:id="@+id/radio_henan"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_henan" />

                <RadioButton
                    android:id="@+id/radio_hunan"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_hunan" />

                <RadioButton
                    android:id="@+id/radio_shanxi"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_shanxi" />

                <RadioButton
                    android:id="@+id/radio_zhejiang"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_zhejiang" />

                <RadioButton
                    android:id="@+id/radio_girl"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_girl" />

                <RadioButton
                    android:id="@+id/radio_boy"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_boy" />

                <RadioButton
                    android:id="@+id/radio_old"
                    style="@style/Widget.CompoundButton.RadioButton.AbsPlayer"
                    android:layout_width="@dimen/tts_player_player_wh"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:text="@string/tts_voice_old" />

            </RadioGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="11.0dip"
                android:drawableTop="@drawable/ic_voice_girl"
                android:text="@string/tts_local_library_play_tips"
                android:textColor="@color/white"
                android:textSize="12.0sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- 朗读标题勾选行 -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="15dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/common_margin_8"
            android:layout_marginStart="@dimen/common_margin_8"
            android:text="@string/label_speak_title"
            android:textColor="@color/voice_text_normal"
            android:textSize="@dimen/txt_size_16" />

        <CheckBox
            android:id="@+id/cb_speak_title"
            android:layout_width="@dimen/tts_player_player_wh"
            android:layout_height="30dp"
            android:background="@drawable/btn_voice_radio_selector"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:gravity="center"
            android:button="@null"
            android:textColor="@color/white"
            android:text="朗读"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:gravity="bottom"
        android:orientation="horizontal" >

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_weight="7.0" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/common_margin_8"
                    android:layout_marginStart="@dimen/common_margin_8"
                    android:text="@string/label_tempo_adjust"
                    android:textColor="@color/voice_text_normal"
                    android:textSize="13.5sp" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="23.0dip"
                    android:paddingRight="23.0dip" >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tempo_slow"
                        android:textColor="@color/voice_text_normal" />

                    <SeekBar
                        android:id="@+id/seekBarSpeed"
                        style="@style/Widget.SeekBar.Text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="9.0dip"
                        android:layout_marginRight="9.0dip"
                        android:layout_weight="1.0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tempo_fast"
                        android:textColor="@color/voice_text_normal" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableLeft="@drawable/ic_setting_selector"
                    android:drawableStart="@drawable/ic_setting_selector"
                    android:drawablePadding="28.0dip"
                    android:text="@string/tts_snda_setting"
                    android:textColor="@color/white"
                    android:textSize="13.5sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="7.0dip"
            android:layout_weight="2.0"
            android:orientation="horizontal" >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:background="@drawable/divider_horizontal" />

            <TextView
                android:id="@+id/btn_clock"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="5.5dip"
                android:drawableTop="@drawable/ic_clock_selector"
                android:gravity="center"
                android:text="00:00"
                android:textColor="@color/voice_text_selector"
                android:textSize="11.0sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/divider_vertical"
        android:orientation="vertical" />

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="50dp"
        android:paddingLeft="32.0dip"
        android:paddingRight="32.0dip" >

        <ImageView
            android:id="@+id/btn_previous_chapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/btn_previous_chapter_selector" />

        <TextView
            android:id="@+id/btn_exit"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:gravity="center_vertical"
            android:paddingBottom="3.0dip"
            android:paddingLeft="50.0dip"
            android:paddingRight="50.0dip"
            android:paddingTop="3.0dip"
            android:text="@string/tts_exit"
            android:textColor="@color/voice_text_selector"
            android:textSize="15.0sp" />

        <ImageView
            android:id="@+id/btn_next_chapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/btn_next_chapter_selector" />
    </RelativeLayout>

</LinearLayout>
