<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">
    <!--顶部-->
    <RelativeLayout
        android:id="@+id/rl_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingTop="@dimen/common_margin_8"
        android:paddingBottom="@dimen/common_margin_8">

        <CheckBox
            android:id="@+id/cb_sort"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/common_margin_16"
            android:layout_marginRight="@dimen/common_margin_8"
            android:background="@drawable/selector_book_remark_sort"
            android:button="@null"
            android:checked="true" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/common_margin_16"
            android:layout_toRightOf="@id/cb_sort"
            android:orientation="horizontal">

            <com.read.scriptures.widget.ClearEditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginRight="@dimen/common_margin_8"
                android:layout_weight="1"
                android:background="@drawable/edit_back_grey"
                android:gravity="center_vertical"
                android:hint="请输入关键词！多个关键词按空格"
                android:imeOptions="actionSearch"
                android:paddingLeft="@dimen/common_margin_8"
                android:paddingRight="@dimen/common_margin_8"
                android:singleLine="true"
                android:textColorHint="#999"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="30dp"
                android:minHeight="30dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_main_color_alpha80"
                android:gravity="center"
                android:text="99+"
                android:textColor="@color/white"
                android:textSize="@dimen/txt_size_12"
                android:visibility="invisible"/>
            <!--            <TextView-->
            <!--                android:id="@+id/tv_search"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="match_parent"-->
            <!--                android:background="@color/green"-->
            <!--                android:paddingLeft="20dp"-->
            <!--                android:paddingTop="10dp"-->
            <!--                android:paddingRight="20dp"-->
            <!--                android:paddingBottom="10dp"-->
            <!--                android:text="搜索"-->
            <!--                android:textColor="@color/white" />-->
        </LinearLayout>

    </RelativeLayout>

    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/rl_top"
        android:background="#F3F3F3" />


    <LinearLayout
        android:id="@+id/ll_bottom_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">


        <!--底部-->
        <LinearLayout
            android:id="@+id/ll_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="@dimen/common_margin_16"
            android:paddingBottom="@dimen/common_margin_16"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_operation_all_checked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/selector_operation_checked_all"
                android:drawablePadding="@dimen/common_margin_8"
                android:gravity="center"
                android:minWidth="80dp"
                android:text="全选"
                android:textColor="@color/selector_operation_text_color"
                android:textSize="@dimen/txt_size_14" />


            <TextView
                android:id="@+id/tv_operation_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/selector_operation_delete"
                android:drawablePadding="@dimen/common_margin_8"
                android:gravity="center"
                android:minWidth="80dp"
                android:text="删除"
                android:textColor="@color/selector_operation_text_color"
                android:textSize="@dimen/txt_size_14" />

            <TextView
                android:id="@+id/tv_operation_copy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/selector_operation_copy"
                android:drawablePadding="@dimen/common_margin_8"
                android:gravity="center"
                android:minWidth="80dp"
                android:text="复制"
                android:textColor="@color/selector_operation_text_color"
                android:textSize="@dimen/txt_size_14" />

        </LinearLayout>
    </LinearLayout>

    <com.baoyz.swipemenulistview.SwipeMenuListView
        android:id="@+id/lv_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/ll_bottom_root"
        android:layout_below="@id/line"
        android:divider="@color/transparent"
        android:dividerHeight="0dp" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="150dp"
        android:drawableTop="@drawable/ic_empty_annotation"
        android:drawablePadding="20dp"
        android:gravity="center"
        android:text="你还没有阅读过任何书籍，快去阅读吧"
        android:textSize="14sp"
        android:visibility="gone" />

</RelativeLayout>