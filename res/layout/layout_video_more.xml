<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_light"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_light"
        android:drawablePadding="20dp"
        android:gravity="center_vertical"
        android:text="模式 • 已关灯"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:visibility="visible" />

    <TextView
        android:id="@+id/tv_share_video"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_video_share"
        android:drawablePadding="20dp"
        android:gravity="center_vertical"
        android:text="分享"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#e4e4e4"
        android:visibility="visible" />

    <TextView
        android:id="@+id/tv_auto_play_next"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_auto_play_next"
        android:drawablePadding="20dp"
        android:gravity="center_vertical"
        android:text="自动下集 • 已开启"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#e4e4e4" />

    <TextView
        android:id="@+id/tv_skip_start"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_skip_start"
        android:drawablePadding="20dp"
        android:gravity="center_vertical"
        android:text="片头/片尾 • 已开启"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#e4e4e4" />

    <TextView
        android:id="@+id/tv_play_speed"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:drawableLeft="@drawable/icon_video_speed"
        android:drawablePadding="20dp"
        android:gravity="center_vertical"
        android:text="播放速度 • 正常"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#e4e4e4" />

    <TextView
        android:id="@+id/tv_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:text="取消"
        android:textColor="@color/black"
        android:textSize="16sp" />

</LinearLayout>
