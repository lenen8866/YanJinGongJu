<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/list_item_layout"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingLeft="@dimen/common_margin_16"
    android:paddingTop="@dimen/common_margin_16"
    android:paddingRight="@dimen/common_margin_16">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <FrameLayout
            android:id="@+id/fl_check"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:clickable="true">

            <CheckBox
                android:id="@+id/cb_select"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/selector_radiobutton_home_type"
                android:button="@null"
                android:clickable="false"
                android:enabled="false" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/fl_check"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_name"
                    style="@style/dg_33_18"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:singleLine="true"
                    android:text="11"
                    android:textStyle="bold" />


                <ImageView
                    android:id="@+id/ze_icon_first"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center_vertical"
                    android:layout_toRightOf="@+id/tv_name"
                    android:background="@drawable/ic_tag_ze"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_category"
                    style="@style/dg_33_12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:singleLine="true"
                    android:text="22"
                    android:textColor="@color/gray_616161" />

                <TextView
                    android:id="@+id/tv_chapter"
                    style="@style/dg_33_16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/common_margin_8"
                    android:layout_marginRight="@dimen/common_margin_8"
                    android:layout_toLeftOf="@id/tv_category"
                    android:layout_toRightOf="@id/ze_icon_first"
                    android:singleLine="true"
                    android:text="33" />

            </RelativeLayout>


            <TextView
                android:id="@+id/tv_content"
                style="@style/dg_66_16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/common_margin_8"
                android:layout_toLeftOf="@id/fl_check"
                android:gravity="center_vertical"
                android:text="eeeeeeeeeeeeeeee" />

            <TextView
                android:id="@+id/tv_description"
                style="@style/dg_orange_16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/common_margin_8"
                android:layout_marginRight="8dp"
                android:layout_toLeftOf="@+id/btn_delete"
                android:text="eeeeeeeeeeeeeeee" />

        </LinearLayout>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="@dimen/common_margin_8"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_book_name"
            style="@style/dg_33_12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:singleLine="true"
            android:text="eeeeeeeeeeeeeeee"
            android:textColor="@color/gray_999999"
            android:visibility="visible" />

        <com.read.scriptures.widget.HorizontalExpandMenu
            android:id="@+id/expanded_menu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="40dp"
            app:button_icon_color="@color/orange"
            app:button_style="right"
            app:expand_time="200"
            app:stroke_color="@color/orange">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_msg"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="短信"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/txt_size_16" />

                <TextView
                    android:id="@+id/tv_copy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="复制"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/txt_size_16" />

                <TextView
                    android:id="@+id/tv_jump"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="跳转"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/txt_size_16" />

                <TextView
                    android:id="@+id/tv_share"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="分享"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/txt_size_16" />

                <TextView
                    android:id="@+id/tv_delete"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="删除"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/txt_size_16" />
            </LinearLayout>
        </com.read.scriptures.widget.HorizontalExpandMenu>
    </RelativeLayout>

    <View
        android:id="@+id/view_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/rl_head"
        android:layout_marginTop="@dimen/common_margin_16"
        android:background="#F3F3F3" />
</LinearLayout>