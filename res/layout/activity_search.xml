<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/common_color_activity_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layout_actionbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_color"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_margin="5dp"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="5dp"
                android:src="@drawable/common_back_selector" />

            <com.read.scriptures.widget.ClearEditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="fill_parent"
                android:layout_marginRight="2dp"
                android:layout_weight="1"
                android:background="@drawable/edit_back_grey"
                android:gravity="center_vertical"
                android:hint="箴2:4搜求它，如搜求珍宝！"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingLeft="8dp"
                android:textColor="@color/gray_4c4c4c"
                android:textColorHint="@color/gray_bdbdbd"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/txt_size_14" />

            <TextView
                android:id="@+id/btn_search"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/search_clickable"
                android:enabled="false"
                android:paddingLeft="20dp"
                android:paddingTop="10dp"
                android:paddingRight="20dp"
                android:paddingBottom="10dp"
                android:text="搜索"
                android:textColor="@color/white" />

        </LinearLayout>

        <RadioGroup
            android:id="@+id/radio_group"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginStart="5dp"
            android:layout_marginLeft="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginRight="5dp"
            android:orientation="horizontal">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                style="@style/dg_33_12"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="@dimen/txt_size_14"
                android:text="搜索："
                android:textColor="@color/white" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rb_1"
                style="@style/dg_33_12"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:button="@null"
                android:drawableLeft="@drawable/selector_radiobutton_white"
                android:drawablePadding="5dp"
                android:text="书籍"
                android:textColor="@color/search_rbtn_color_selector" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rb_3"
                style="@style/dg_33_12"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:button="@null"
                android:drawableLeft="@drawable/selector_radiobutton_white"
                android:drawablePadding="5dp"
                android:text="目录"
                android:textColor="@color/search_rbtn_color_selector" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rb_2"
                style="@style/dg_33_12"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:button="@null"
                android:drawableLeft="@drawable/selector_radiobutton_white"
                android:drawablePadding="5dp"
                android:text="标题"
                android:textColor="@color/search_rbtn_color_selector" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <RadioButton
                android:id="@+id/rb_4"
                style="@style/dg_33_12"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:button="@null"
                android:checked="true"
                android:drawableLeft="@drawable/selector_radiobutton_white"
                android:drawablePadding="5dp"
                android:text="内容"
                android:textColor="@color/search_rbtn_color_selector" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@+id/radio_group"
            android:background="@color/common_color_list_line" />

        <LinearLayout
            android:id="@+id/tv_father_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/radio_group"
            android:background="@color/common_color_layout_bg"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_search"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_weight="2"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:singleLine="true"
                android:text="搜索历史"
                android:textColor="#ff424142"
                android:textSize="16.0sp" />

            <TextView
                android:id="@+id/tv_remain"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/dialog_btn_middle"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:singleLine="true"
                android:text="重置搜索"
                android:textColor="#ff424142"
                android:textSize="16.0sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="gone">

                <TextView
                    android:id="@+id/switch_show_content"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_gravity="right|center_vertical"
                    android:background="@drawable/custom_item_selector"
                    android:clickable="true"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="15dp"
                    android:text="切换显示"
                    android:textColor="#ff424142"
                    android:textSize="16.0sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/searchTotalCountText"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:background="#c3f0c6"
            android:paddingLeft="10dp"
            android:gravity="center_vertical"
            android:textSize="15sp"/>
    </LinearLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/layout_actionbar">

        <LinearLayout
            android:id="@+id/ll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/layout_result"
                    android:layout_width="fill_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_result"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_white_top_bottom_stroke"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:textColor="#ff424142"
                        android:textSize="16.0sp" />

                    <com.read.scriptures.widget.XListView
                        android:id="@+id/listview_result"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:cacheColorHint="@color/orange_fff3e0"
                        android:divider="@color/common_color_line_bg"
                        android:dividerHeight="1dp"
                        android:drawSelectorOnTop="false"
                        android:fadeScrollbars="true"
                        android:fastScrollEnabled="true"
                        android:focusable="true"
                        android:scrollbars="vertical" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/fl_progress"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@color/common_color_activity_bg"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/search_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_below="@+id/tv_father_search"
                        android:layout_marginTop="@dimen/common_margin_8"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progressbar_color" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/content_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/tv_father_search"
                android:orientation="vertical"
                android:visibility="gone">

                <include layout="@layout/popup_search_content_options" />
            </LinearLayout>


        </LinearLayout>

    </FrameLayout>

    <ListView
        android:id="@+id/listview_history"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="49dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/btn_black_border"
        android:cacheColorHint="@color/orange_fff3e0"
        android:divider="@color/transparent"
        android:dividerHeight="0dp"
        android:drawSelectorOnTop="false"
        android:fadeScrollbars="true"
        android:fastScrollEnabled="false"
        android:focusable="true"
        android:scrollbars="vertical"
        android:visibility="gone" />

    <View
        android:id="@+id/touch_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/actionbar_height" />
</RelativeLayout>