<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F3F3F3">

    <com.read.scriptures.view.VideoRecordProgressBar
        android:id="@+id/hp_progress"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        app:layout_constraintTop_toBottomOf="@+id/view_top" />

    <com.read.scriptures.view.CirclePercentView
        android:id="@+id/cpv_progress"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        app:circleBgColor="@color/white"
        app:circleIsGradient="true"
        app:circleProgressColor="#ff9800"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hp_progress" />

    <ImageView
        android:id="@+id/iv_cover"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="@+id/cpv_progress"
        app:layout_constraintLeft_toLeftOf="@+id/cpv_progress"
        app:layout_constraintRight_toRightOf="@+id/cpv_progress"
        app:layout_constraintTop_toTopOf="@+id/cpv_progress" />

    <LinearLayout
        android:gravity="center_vertical"
        android:id="@+id/ll_chapter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/amt_book"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintLeft_toRightOf="@+id/cpv_progress"
        app:layout_constraintRight_toLeftOf="@+id/iv_playing_pause"
        app:layout_constraintTop_toBottomOf="@+id/hp_progress">

        <com.read.scriptures.view.AutoMarqueeTextView
            android:id="@+id/amt_chapter"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text=""
            android:textColor="#101010"
            android:textSize="13sp" />

        <ProgressBar
            android:visibility="gone"
            android:id="@+id/pb_loading"
            style="?android:attr/progressBarStyle"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginLeft="3dp" />

    </LinearLayout>

    <com.read.scriptures.view.AutoMarqueeTextView
        android:id="@+id/amt_book"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:textColor="#aa101010"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@+id/amt_cate"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintLeft_toLeftOf="@+id/ll_chapter"
        app:layout_constraintRight_toLeftOf="@+id/iv_playing_pause"
        app:layout_constraintTop_toBottomOf="@+id/ll_chapter" />

    <com.read.scriptures.view.AutoMarqueeTextView
        android:id="@+id/amt_cate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text=""
        android:textColor="#aa101010"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintLeft_toLeftOf="@+id/ll_chapter"
        app:layout_constraintRight_toLeftOf="@+id/iv_playing_pause"
        app:layout_constraintTop_toBottomOf="@+id/amt_book" />

    <ImageView
        android:id="@+id/iv_playing_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/icon_playing_play"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/iv_playing_next"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_playing_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/icon_playing_next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/iv_playing_list"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_playing_list"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="10dp"
        android:src="@drawable/icon_playing_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#eeeeee"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>