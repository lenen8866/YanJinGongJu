<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/common_color_activity_bg">

    <LinearLayout
        android:id="@+id/layout_actionbar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/main_color"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp"
            android:src="@drawable/common_back_selector" />

        <com.read.scriptures.widget.ClearEditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_marginRight="2dp"
            android:layout_weight="1"
            android:background="@drawable/edit_back_grey"
            android:gravity="center_vertical"
            android:hint="请输入书籍或视频名字"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingLeft="8dp"
            android:textColor="@color/gray_4c4c4c"
            android:textColorHint="@color/gray_bdbdbd"
            android:textCursorDrawable="@null"
            android:textSize="@dimen/txt_size_14" />

        <TextView
            android:id="@+id/btn_search"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/search_clickable"
            android:enabled="false"
            android:paddingLeft="20dp"
            android:paddingTop="10dp"
            android:paddingRight="20dp"
            android:paddingBottom="10dp"
            android:text="搜索"
            android:textColor="@color/white" />

    </LinearLayout>

    <RadioGroup
        android:id="@+id/radio_group"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/main_color"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/layout_actionbar">

        <TextView
            style="@style/dg_33_12"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="15dp"
            android:gravity="center"
            android:text="搜索："
            android:textColor="@color/white"
            android:textSize="@dimen/txt_size_14"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/rb_1"
            style="@style/dg_33_12"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:button="@null"
            android:drawableLeft="@drawable/selector_radiobutton_white"
            android:drawablePadding="3dp"
            android:paddingLeft="10dp"
            android:text="书籍/专辑"
            android:textColor="@color/search_rbtn_color_selector"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_2"
            style="@style/dg_33_12"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:button="@null"
            android:checked="true"
            android:drawableLeft="@drawable/selector_radiobutton_white"
            android:drawablePadding="3dp"
            android:paddingLeft="10dp"
            android:text="章节/视频"
            android:textColor="@color/search_rbtn_color_selector"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/rb_3"
            style="@style/dg_33_12"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:button="@null"
            android:drawableLeft="@drawable/selector_radiobutton_white"
            android:drawablePadding="3dp"
            android:paddingLeft="10dp"
            android:text="作者/歌手"
            android:textColor="@color/search_rbtn_color_selector"
            android:textSize="13sp"
            android:visibility="invisible" />
    </RadioGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_cate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="10dp"
        app:layout_constraintTop_toBottomOf="@+id/radio_group" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_count" />

    <TextView
        android:id="@+id/tv_count"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@drawable/icon_search_count_bg"
        android:drawableLeft="@drawable/icon_search_success"
        android:gravity="center_vertical"
        android:paddingLeft="15dp"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/rcv_cate" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_cache_search"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="45dp"
        android:layout_marginTop="1dp"
        android:layout_marginRight="75dp"
        android:background="@drawable/btn_black_border"
        android:cacheColorHint="@color/orange_fff3e0"
        android:drawSelectorOnTop="false"
        android:fadeScrollbars="true"
        android:fastScrollEnabled="false"
        android:focusable="true"
        android:maxHeight="220dp"
        android:padding="1dp"
        android:scrollbars="vertical"
        android:textCursorDrawable="@null"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="@+id/layout_actionbar"
        app:layout_constraintRight_toRightOf="@+id/layout_actionbar"
        app:layout_constraintTop_toBottomOf="@+id/layout_actionbar" />

</androidx.constraintlayout.widget.ConstraintLayout>