<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.read.scriptures.widget.WHProportionRelativeLayout
        android:id="@+id/rl_root_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_level_price_checked_bg"
        android:clickable="true"
        app:proportion="1:1">

        <LinearLayout
            android:id="@+id/ll_price_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_size_14"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:text="0"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_size_18"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/ll_price_info"
            android:layout_centerHorizontal="true"
            android:text="12"
            android:textColor="@color/orange_ffa726"
            android:textSize="@dimen/txt_size_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_origin_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/ll_price_info"
            android:layout_centerHorizontal="true"
            android:text="¥0"
            android:textColor="@color/gray_999999"
            android:textSize="@dimen/txt_size_12" />
    </com.read.scriptures.widget.WHProportionRelativeLayout>


</LinearLayout>