<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
				xmlns:tools="http://schemas.android.com/tools"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#292423"
				android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/iv_back_margin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="5dp"
                android:layout_marginRight="5dp"
                android:src="@drawable/ic_back_white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自定义行间距"
                android:textColor="@color/white"
                android:layout_marginRight="20dp"
                android:layout_gravity="center_vertical"/>

            <TextView
                android:id="@+id/return_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="恢复默认设置"
                android:textColor="@color/white"
                android:layout_gravity="center_vertical"/>

        </LinearLayout>

    </LinearLayout>

    <include layout="@layout/dex_line"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="行间距"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:layout_marginRight="20dp"
                    android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tv_line_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20"
                    android:textColor="@color/white"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/line_seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="6"
                android:focusable="true"
                android:max="100"
                android:layout_gravity="center_vertical"
                android:maxHeight="1dip"
                android:minHeight="1dip"
                android:progressDrawable="@drawable/po_seekbar"
                android:thumb="@drawable/seekbar_thumb_white"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@color/gray_9e9e9e"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="段间距"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:layout_marginRight="20dp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tv_section_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20"
                    android:textColor="@color/white"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/section_seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="6"
                android:focusable="true"
                android:max="100"
                android:layout_gravity="center_vertical"
                android:maxHeight="1dip"
                android:minHeight="1dip"
                android:progressDrawable="@drawable/po_seekbar"
                android:thumb="@drawable/seekbar_thumb_white"/>
        </LinearLayout>
    </LinearLayout>

