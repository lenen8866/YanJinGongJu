<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_history"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_top_bottom_stroke"
        android:orientation="horizontal" >

        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="2"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:text="搜索历史"
            android:textColor="#ff424142"
            android:textSize="16.0sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" >

            <TextView
                android:id="@+id/clear_search_history"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_gravity="right|center_vertical"
                android:background="@drawable/custom_item_selector"
                android:clickable="true"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="15dp"
                android:text="清空历史"
                android:textColor="#ff424142"
                android:textSize="16.0sp" />
        </LinearLayout>
    </LinearLayout>

    <ListView
        android:id="@+id/listview_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:cacheColorHint="@color/orange_fff3e0"
        android:divider="@color/transparent"
        android:dividerHeight="0dp"
        android:drawSelectorOnTop="false"
        android:fadeScrollbars="true"
        android:fastScrollEnabled="false"
        android:focusable="true"
        android:scrollbars="vertical" />

</LinearLayout>