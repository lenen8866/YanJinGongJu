<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:layout_width="match_parent"
        android:layout_height="45dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="45dp"
            android:layout_toLeftOf="@+id/tv_answer_count"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_answer_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@drawable/icon_answer_ok"
                android:drawablePadding="5dp"
                android:text="0"
                android:textColor="@color/main_color"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_answer_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:drawableLeft="@drawable/icon_wrong"
                android:drawablePadding="5dp"
                android:text="0"
                android:textColor="@color/red"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_answer_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="20dp"
            android:drawablePadding="5dp"
            android:gravity="center_vertical"
            android:text="0/200"
            android:textColor="@color/black"
            android:textSize="13sp" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:clipToPadding="false"
        android:paddingBottom="10dp"
        android:paddingRight="7dp"
        android:paddingLeft="7dp"
        android:id="@+id/rcv_question_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>