<?xml version="1.0" encoding="utf-8"?>
<!-- 检查单位item布局 -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/listview_item_pressed_style"
    android:gravity="center_vertical"
    android:paddingBottom="5dp"
    android:paddingEnd="2dp"
    android:paddingLeft="8dp"
    android:paddingRight="2dp"
    android:paddingStart="8dp"
    android:paddingTop="5dp" >

    <TextView
        android:id="@+id/select_dialog_list_item_show"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:padding="8dp"
        android:textColor="#626466"
        android:gravity="center"
        android:textSize="20sp" />

    <ImageView
        android:id="@+id/select_dialog_list_item_show_del"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/select_dialog_list_item_show"
        android:layout_alignEnd="@id/select_dialog_list_item_show"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_alignRight="@id/select_dialog_list_item_show"
        android:layout_alignTop="@+id/select_dialog_list_item_show"
        android:layout_marginEnd="10dp"
        android:layout_marginRight="10dp"
        android:clickable="true"
        android:contentDescription="@string/about_activate"
        android:src="@drawable/del" />

</RelativeLayout>