<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_donate_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="5dp"
        android:text="无偿捐款"
        android:textColor="@color/black"
        android:textSize="20sp" />

    <LinearLayout
        android:id="@+id/ll_donate_number"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_btn_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="5dp"
            android:text="捐献金额：" />

        <com.read.scriptures.widget.ClearEditText
            android:id="@+id/et_donate_number"
            android:layout_width="0dp"
            android:layout_height="fill_parent"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:background="@color/transparent"
            android:hint="请输入大于0元的金额"
            android:imeOptions="actionSearch"
            android:inputType="number|numberDecimal"
            android:maxLength="7"
            android:paddingLeft="8dp"
            android:textColor="@color/gray_4c4c4c"
            android:textColorHint="@color/gray_bdbdbd"
            android:textCursorDrawable="@null"
            android:textSize="@dimen/txt_size_16" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical">

        <com.read.scriptures.widget.ListViewForScrollView
            android:id="@+id/lv_pay_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:divider="@color/transparent"
            android:dividerHeight="0dp"
            android:orientation="vertical"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/tv_confirm_pay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:background="@drawable/btn_wxpay_selector"
            android:gravity="center"
            android:padding="7dp"
            android:text="确认支付"
            android:textSize="@dimen/txt_size_16"
            android:textColor="@color/white" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/part_line" />

    <TextView
        android:id="@+id/tv_close"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_btn_bottom"
        android:gravity="center"
        android:text="@string/close"
        android:textColor="@color/black"
        android:textSize="16sp" />

</LinearLayout>