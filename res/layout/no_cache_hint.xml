<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rl_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
		android:id="@+id/rl_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
		android:layout_centerInParent="true"
        android:background="@color/white">

        <com.read.scriptures.widget.Video.WxPlayer
            android:id="@+id/wx_player"
            android:layout_width="wrap_content"
            android:layout_height="200dp"
            android:layout_alignParentTop="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/dialog_btn_bottom"
            android:gravity="center"
            android:text="@string/close"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <View
            android:id="@+id/dex_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_above="@id/tv_close"
            android:background="@color/part_line" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/dex_line"
            android:layout_below="@id/wx_player">

            <TextView
                android:id="@+id/tv_join"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dialog_btn_top"
                android:padding="16dp"
                android:textColor="#333333"
                android:textIsSelectable="true"
                android:textSize="16sp" />
        </ScrollView>

    </RelativeLayout>


</RelativeLayout>