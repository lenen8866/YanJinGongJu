<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/main_color"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/common_margin_8"
            android:src="@drawable/common_back_selector" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="给好友账户充值"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_actionbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_color"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/rl_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="2dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.read.scriptures.widget.ClearEditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="fill_parent"
                android:layout_marginRight="2dp"
                android:layout_weight="1"
                android:background="@drawable/edit_back_grey"
                android:gravity="center_vertical"
                android:hint="请输入用户账户"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingLeft="8dp"
                android:textColor="@color/gray_4c4c4c"
                android:textColorHint="@color/gray_bdbdbd"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/txt_size_14" />

            <TextView
                android:id="@+id/btn_search"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/search_clickable"
                android:enabled="false"
                android:paddingLeft="20dp"
                android:paddingTop="10dp"
                android:paddingRight="20dp"
                android:paddingBottom="10dp"
                android:text="充值"
                android:textColor="@color/white" />

        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_actionbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_search_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="80dp"
        android:background="@drawable/btn_black_border"
        android:cacheColorHint="@color/orange_fff3e0"
        android:drawSelectorOnTop="false"
        android:fadeScrollbars="true"
        android:fastScrollEnabled="false"
        android:focusable="true"
        android:maxHeight="220dp"
        android:padding="1dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="@+id/layout_actionbar"
        app:layout_constraintRight_toRightOf="@+id/layout_actionbar"
        app:layout_constraintTop_toBottomOf="@+id/layout_actionbar" />


</androidx.constraintlayout.widget.ConstraintLayout>